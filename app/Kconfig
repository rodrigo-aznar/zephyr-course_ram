config DEBUG_MY_BOARD
    bool "Enable debug on my board"
    default n
    help
        enable debug on the board with LEDs  

menuconfig LED_SUBSYSTEM
    bool "LED Subsystem"
    default y

if LED_SUBSYSTEM

    choice 
        prompt "LED blink speed"
        default BLINK_SLEEP_1000MS

    config BLINK_SLEEP_250MS
        bool "SuperFast"

    config BLINK_SLEEP_500MS
        bool "Fast"

    config BLINK_SLEEP_1000MS
        bool "Normal"

    config BLINK_SLEEP_2000MS    
        bool "Slow"
        
    endchoice


    config BLINK_SLEEP_TIME_MS
        int 
        default 250 if BLINK_SLEEP_250MS
        default 500 if BLINK_SLEEP_500MS
        default 1000 if BLINK_SLEEP_1000MS
        default 2000 if BLINK_SLEEP_2000MS
        range 100 5000
        help 
            set the blink sleep time (ms) between 100 and 5000 
            (1000 is the default)

    menuconfig ADVANCED_LED_SETTINGS
        bool "Advanced LED settings"
        default y

    if ADVANCED_LED_SETTINGS

        config LED_BRIGHTNESS
            int "LED brightness (0-100)"
            default 100
            range 0 100
            help 
                set the LED brightness between 0 and 100
                (100 is the default)            

        config LED_FADE_DURATION
            int "LED fade duration(ms)"
            default 500
            range 0 5000
            help 
                set the LED fade duration between 0 and 5000 ms
                (500 is the default)    

        menu "Expert settings"
            visible if DEBUG_MY_BOARD
            config LED_DEBUG
                bool "Enable LED debugging"
                default y
                help
                    enable LED debugging

            config CUSTOM_BLINK_PATTERN
                bool "Custom blink pattern"
                default y
                help
                    enable the custom blink pattern                
        endmenu


    endif # ADVANCED_LED_SETTINGS    

endif # LED_SUBSYSTEM


source "Kconfig.zephyr"